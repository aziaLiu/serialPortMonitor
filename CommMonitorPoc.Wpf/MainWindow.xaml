<Window x:Class="CommMonitorPoc.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="串口监视助手"
        Icon="favicon.ico"
        Width="1220"
        Height="730"
        MinWidth="1060"
        MinHeight="650"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFF7F2EA" Offset="0" />
                <GradientStop Color="#FFE6D8CB" Offset="0.55" />
                <GradientStop Color="#FFDCE6E9" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Margin="14,12,14,10"
                Padding="18,14,18,14"
                CornerRadius="28"
                Background="{StaticResource InkBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"
                               Text="串口监视助手" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="#E7FFFFFF"
                               Text="基于已恢复的 CommMonitor 驱动协议实现的 WPF 监视界面" />
                </StackPanel>

                <Border Grid.Column="1"
                        Width="170"
                        Height="68"
                        CornerRadius="20"
                        HorizontalAlignment="Right">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFDA6A3A" Offset="0" />
                            <GradientStop Color="#FFF2BF7A" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Margin="14,11">
                        <TextBlock FontSize="12"
                                   Foreground="#CC17212B"
                                   Text="当前状态" />
                        <TextBlock Margin="0,8,0,0"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#FF17212B"
                                   Text="{Binding StatusText}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="14,0,14,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="抓包控制" />

                        <DockPanel Margin="0,12,0,0">
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="串口列表" />
                            <Button DockPanel.Dock="Right"
                                    Width="60"
                                    Height="26"
                                    Margin="10,0,0,0"
                                    Content="刷新"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Command="{Binding RefreshPortsCommand}" />
                        </DockPanel>

                        <Border Margin="0,8,0,0"
                                Height="92"
                                CornerRadius="12"
                                Background="White"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding AvailablePorts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Margin="10,6,10,0"
                                                      Content="{Binding Name}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>

                        <CheckBox Margin="0,12,0,0"
                                  Content="保存原始抓包文件"
                                  IsChecked="{Binding SaveArtifacts}" />

                        <CheckBox Margin="0,8,0,0"
                                  Content="跟随最新"
                                  IsChecked="{Binding FollowLatest}" />

                        <Button Width="168"
                                Margin="0,12,0,0"
                                Content="{Binding CaptureButtonText}"
                                Command="{Binding CaptureToggleCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource DangerBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="2*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="92" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="选中数据包" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,10,0,0"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Text="概要" />

                        <TextBlock Grid.Row="2"
                                   Margin="0,6,0,0"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Text="{Binding SelectedSummary}" />

                        <Grid Grid.Row="3"
                              Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                       Text="报文 HEX" />
                            <TextBox Grid.Row="1"
                                     Margin="0,6,0,0"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Visible"
                                     Text="{Binding SelectedHex, Mode=OneWay}"
                                     IsReadOnly="True" />
                        </Grid>

                        <Grid Grid.Row="5"
                              Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                       Text="ASCII" />
                            <TextBox Grid.Row="1"
                                     Margin="0,6,0,0"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Visible"
                                     Text="{Binding SelectedAscii, Mode=OneWay}"
                                     IsReadOnly="True" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="2"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="实时数据流" />
                        <TextBlock Margin="12,4,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Text="{Binding PacketCountText}" />
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              Margin="0,18,0,0"
                              ItemsSource="{Binding Packets}"
                              SelectedItem="{Binding SelectedPacket}"
                              IsReadOnly="True"
                              FrozenColumnCount="4">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Time}" Header="时间" Width="118" />
                            <DataGridTextColumn Binding="{Binding Port}" Header="串口" Width="78" />
                            <DataGridTextColumn Binding="{Binding Direction}" Header="方向" Width="68" />
                            <DataGridTextColumn Binding="{Binding Kind}" Header="类型" Width="110" />
                            <DataGridTextColumn Binding="{Binding Hex}" Header="报文" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
